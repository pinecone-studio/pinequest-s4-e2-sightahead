{
  "manifest_version": 3,
  "name": "SightAhead - YouTube Dubbing",
  "version": "0.1.0",
  "description": "Dub YouTube videos into Mongolian",

  "permissions": ["activeTab"],

  "host_permissions": [
    "*://www.youtube.com/*",
    "*://youtube.com/*",
    "https://pinequest-s4-e2-sightahead.onrender.com/*",
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/watch*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],

  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
